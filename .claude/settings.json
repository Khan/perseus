{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "sandbox": {
        "filesystem": {
            "allowWrite": [
                ".",
                "/tmp/claude",
                "/private/tmp/claude",
                "~/.claude/session-env",
                "~/.claude/debug",
                "~/.cache/gh",
                "~/khan/devtools/khan-linter",
                "~/.npm",
                "~/.local/share/mise",
                "~/.local/state/mise",
                "~/.cache/node/corepack",
                "~/Library/pnpm"
            ],
            "denyWrite": [
                ".claude/settings.json",
                ".claude/hooks",
                "~/.claude/settings.json",
                "~/.claude/hooks"
            ]
        },
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "allowUnsandboxedCommands": false,
        "network": {
            "allowLocalBinding": true,
            "allowedDomains": [
                "localhost",
                "github.com",
                "api.github.com",
                "registry.npmjs.org",
                "npm.pkg.github.com",
                "download.cypress.io",
                "cdn.cypress.io",
                "cdn.jsdelivr.net"
            ]
        },
        "enableWeakerNetworkIsolation": true,
        "excludedCommands": [
            "pbcopy",
            "pnpm cypress:clean",
            "pnpm cypress:secrets",
            "pnpm cypress",
            "pnpm cypress:dev",
            "pnpm cypress:dev-open",
            "pnpm cypress:open-kadev",
            "pnpm build",
            "pnpm build:types",
            "pnpm watch",
            "pnpm test",
            "pnpm test *",
            "pnpm jest",
            "pnpm jest *"
        ]
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-token-init.mjs"
                    }
                ]
            },
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gh-install.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "pnpm install",
                        "timeout": 120,
                        "statusMessage": "Installing dependencies..."
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "if": "Bash(git *)",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-filter.mjs"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "if": "Bash(gh *)",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gh-filter.mjs"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "ask": [
            "mcp__*"
        ],
        "allow": [
            "Bash(pbcopy)",
            "Bash(pnpm cypress:clean)",
            "Bash(pnpm cypress:secrets)",
            "Bash(pnpm cypress)",
            "Bash(pnpm cypress:dev)",
            "Bash(pnpm cypress:dev-open)",
            "Bash(pnpm cypress:open-kadev)",
            "Bash(pnpm build)",
            "Bash(pnpm build:types)",
            "Bash(pnpm watch)",
            "Bash(pnpm test)",
            "Bash(pnpm test *)",
            "Bash(pnpm jest)",
            "Bash(pnpm jest *)"
        ]
    }
}
