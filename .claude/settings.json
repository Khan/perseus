{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "deny": [
            "Edit(.claude/settings.json)",
            "Write(.claude/settings.json)",
            "Edit(.claude/hooks/**)",
            "Write(.claude/hooks/**)",
            "Edit(~/.claude/settings.json)",
            "Write(~/.claude/settings.json)",
            "Edit(~/.claude/hooks/**)",
            "Write(~/.claude/hooks/**)",
            "Read(**/id_rsa*)",
            "Read(**/id_ed25519*)",
            "Read(**/id_ecdsa*)",
            "Read(**/id_dsa*)",
            "Read(**/.ssh/id_*)",
            "Read(**/.aws/credentials)",
            "Read(**/.aws/config)",
            "Read(**/.config)"
        ],
        "allow": [
            "Edit(/tmp/**)",
            "Write(/tmp/**)",
            "Read(/tmp/**)",
            "Edit(/private/tmp/**)",
            "Write(/private/tmp/**)",
            "Read(/private/tmp/**)",
            "Read(~/.claude/session-env/**)",
            "Edit(~/.claude/session-env/**)",
            "Write(~/.claude/session-env/**)",
            "Read(~/.claude/debug/**)",
            "Write(~/.claude/debug/**)",
            "Edit(~/.cache/gh/**)",
            "Write(~/.cache/gh/**)",
            "Read(~/.cache/gh/**)",
            "Read(~/khan/devtools/khan-linter/**)",
            "Edit(~/khan/devtools/khan-linter/**)",
            "Read(~/.npm/**)",
            "Edit(~/.npm/**)",
            "Write(~/.npm/**)",
            "Read(~/.local/share/mise)",
            "Edit(~/.local/share/mise)",
            "Write(~/.local/share/mise)",
            "Read(~/.local/state/mise)",
            "Edit(~/.local/state/mise)",
            "Write(~/.local/state/mise)",
            "Read(~/.cache/node/corepack)",
            "Edit(~/.cache/node/corepack)",
            "Write(~/.cache/node/corepack)",
            "Read(~/Library/pnpm/**)",
            "Edit(~/Library/pnpm/**)",
            "Write(~/Library/pnpm/**)",
            "Bash(pnpm cypress:clean)",
            "Bash(pnpm cypress:secrets)",
            "Bash(pnpm cypress)",
            "Bash(pnpm cypress:dev)",
            "Bash(pnpm cypress:dev-open)",
            "Bash(pnpm cypress:open-kadev)",
            "Bash(pnpm build)",
            "Bash(pnpm build:types)",
            "Bash(pnpm watch)"
        ],
        "ask": [
            "mcp__*"
        ]
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "allowUnsandboxedCommands": false,
        "network": {
            "allowLocalBinding": true,
            "allowedDomains": [
                "localhost",
                "github.com",
                "api.github.com",
                "registry.npmjs.org",
                "npm.pkg.github.com",
                "download.cypress.io"
            ]
        },
        "enableWeakerNetworkIsolation": true,
        "excludedCommands": [
            "pnpm cypress:clean",
            "pnpm cypress:secrets",
            "pnpm cypress",
            "pnpm cypress:dev",
            "pnpm cypress:dev-open",
            "pnpm cypress:open-kadev",
            "pnpm build",
            "pnpm build:types",
            "pnpm watch"
        ]
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-token-init.mjs"
                    }
                ]
            },
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gh-install.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "pnpm install",
                        "timeout": 120,
                        "statusMessage": "Installing dependencies..."
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "if": "Bash(git *)",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-filter.mjs"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "if": "Bash(gh *)",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gh-filter.mjs"
                    }
                ]
            }
        ]
    }
}
