{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "sandbox": {
        "filesystem": {
            "allowWrite": [
                ".",
                "/tmp",
                "/private/tmp",
                "~/.claude/session-env",
                "~/.claude/debug",
                "~/.cache/gh",
                "~/khan/devtools/khan-linter",
                "~/.npm",
                "~/.local/share/mise",
                "~/.local/state/mise",
                "~/.cache/node/corepack",
                "~/Library/pnpm",
                "~/Library/Caches/pnpm"
            ],
            "denyWrite": [
                ".claude/settings.json",
                ".claude/hooks",
                "~/.claude/settings.json",
                "~/.claude/hooks",
                ".mcp.json",
                ".mcp",
                ".agent-settings-assets-manifest.json",
                ".codex/config.toml"
            ],
            "allowGitConfig": true
        },
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "allowUnsandboxedCommands": false,
        "network": {
            "allowLocalBinding": true,
            "allowedDomains": [
                "localhost",
                "github.com",
                "api.github.com",
                "registry.npmjs.org",
                "npm.pkg.github.com",
                "download.cypress.io",
                "cdn.cypress.io"
            ]
        },
        "enableWeakerNetworkIsolation": true,
        "excludedCommands": [
            "pbcopy",
            "pnpm cypress:clean",
            "pnpm cypress:secrets",
            "pnpm cypress",
            "pnpm cypress:dev",
            "pnpm cypress:dev-open",
            "pnpm cypress:open-kadev",
            "pnpm build",
            "pnpm build:types",
            "pnpm watch"
        ]
    },
    "permissions": {
        "deny": [
            "Edit(.mcp.json)",
            "Edit(.mcp/**)",
            "Edit(.agent-settings-assets-manifest.json)",
            "Edit(.codex/config.toml)",
            "mcp__google_cloud_bigquery__execute_sql",
            "mcp__claude_ai_Google_Cloud_BigQuery__execute_sql"
        ],
